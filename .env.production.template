# =============================================================================
# SAUDAPAKKA — PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# 1. Copy this file:  cp .env.production.template .env
# 2. Fill in all values below
# 3. NEVER commit .env to git
# =============================================================================

# --- Django ---
SECRET_KEY=your-very-long-random-secret-key-at-least-50-chars
DEBUG=False

# --- Database ---
POSTGRES_DB=saudapakka_db
POSTGRES_USER=hello_django
POSTGRES_PASSWORD=your-strong-db-password-here

# --- Email (Gmail SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=SaudaPakka <your-gmail@gmail.com>

# --- Sandbox KYC ---
SANDBOX_API_KEY=your-sandbox-api-key
SANDBOX_API_SECRET=your-sandbox-api-secret
SANDBOX_BASE_URL=https://api.sandbox.co.in
SANDBOX_ENV=production

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Frontend ---
NEXT_PUBLIC_BACKEND_URL=https://saudapakka.com
NEXT_PUBLIC_API_URL=https://saudapakka.com
